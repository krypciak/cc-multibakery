{
    "name": "cc-multibakery",
    "version": "0.8.1",
    "type": "module",
    "scripts": {
        "start": "bun build/build.ts build",
        "watch": "bun build/build.ts watch",
        "build": "bun build/build.ts build dev=false",
        "pack": "bun pack.ts",
        "regenerateBin": "bun build/build.ts build forceRegenerateBinaryEncodeDecodeScripts",
        "buildRemote": "bun build/build.ts build dev=false minifySyntax minifyWhitespace physics=false",
        "buildRemoteBrowser": "bun build/build.ts build dev=false minifySyntax minifyWhitespace physics=false browser target=es2024",
        "buildPhysics": "bun build/build.ts build dev=false minifySyntax minifyWhitespace remote=false",
        "buildPhysicsNetless": "bun build/build.ts build dev=false minifySyntax minifyWhitespace remote=false physicsnet=false",
        "buildCrossnode": "bun build/build.ts build dev=false remote=false target=esnext crossnode",
        "buildTest": "bun build/build.ts build dev target=esnext crossnode test",
        "format": "prettier ./src -w; npx prettier ./assets -w --tab-width 4 --no-semi --print-width 400 --bracket-same-line",
        "test": "bun test --parallel --isolate --concurrent",
        "server": "NODE_NO_WARNINGS=1 node --enable-source-maps scripts/server.js",
        "serverBun": "bun run scripts/server.js"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/chrome": "^0.2.2",
        "@types/jquery": "^4.0.1",
        "@types/node": "^26.1.0",
        "@types/ws": "^8.18.1",
        "bun": "^1.3.14",
        "cc-instanceinator": "github:krypciak/cc-instanceinator",
        "cc-jetpack-widget": "github:krypciak/cc-jetpack-widget",
        "cc-krypek-lib": "github:krypciak/cc-krypek-lib",
        "cc-variable-charge-time": "github:krypciak/cc-variable-charge-time",
        "ccmoddb": "github:CCDirectLink/CCModDB",
        "ccmodmanager": "github:CCDirectLink/CCModManager",
        "crosscode-web": "github:krypciak/crosscode-web",
        "crossnode": "github:krypciak/crossnode",
        "esbuild": "^0.28.1",
        "fflate": "^0.8.3",
        "nax-ccuilib": "github:krypciak/nax-ccuilib",
        "node": "^26.4.0",
        "prettier": "3.9.4",
        "socket.io": "^4.8.3",
        "socket.io-adapter": "^2.5.8",
        "socket.io-client": "^4.8.3",
        "spdy": "^4.0.2",
        "ts-binarifier": "github:krypciak/ts-binarifier",
        "typescript": "^6.0.3",
        "ultimate-crosscode-typedefs": "github:krypciak/ultimate-crosscode-typedefs",
        "ws": "^8.21.0"
    }
}
