{
    "name": "cc-multibakery",
    "version": "0.7.9",
    "type": "module",
    "scripts": {
        "start": "bun build/build.ts build",
        "watch": "bun build/build.ts watch",
        "build": "bun build/build.ts build dev=false",
        "regenerateBin": "bun build/build.ts build forceRegenerateBinaryEncodeDecodeScripts=true",
        "buildRemote": "bun build/build.ts build dev=false minifySyntax=true minifyWhitespace=true physics=false",
        "buildRemoteBrowser": "bun build/build.ts build dev=false minifySyntax=true minifyWhitespace=true physics=false browser=true target=es2024",
        "buildPhysics": "bun build/build.ts build dev=false minifySyntax=true minifyWhitespace=true remote=false",
        "buildPhysicsNetless": "bun build/build.ts build dev=false minifySyntax=true minifyWhitespace=true remote=false physicsnet=false",
        "format": "prettier ./src -w; npx prettier ./assets -w --tab-width 4 --no-semi --print-width 400 --bracket-same-line",
        "test": "NODE_NO_WARNINGS=1 node --enable-source-maps scripts/test.js",
        "server": "NODE_NO_WARNINGS=1 node --enable-source-maps scripts/server.js"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/chrome": "^0.1.38",
        "@types/jquery": "^4.0.0",
        "@types/node": "^25.5.0",
        "@types/ws": "^8.18.1",
        "bun": "^1.3.11",
        "cc-instanceinator": "github:krypciak/cc-instanceinator",
        "cc-jetpack-widget": "github:krypciak/cc-jetpack-widget",
        "cc-krypek-lib": "github:krypciak/cc-krypek-lib",
        "cc-variable-charge-time": "github:krypciak/cc-variable-charge-time",
        "ccmoddb": "github:CCDirectLink/CCModDB",
        "ccmodmanager": "github:CCDirectLink/CCModManager",
        "crosscode-web": "github:krypciak/crosscode-web",
        "crossnode": "github:krypciak/crossnode",
        "esbuild": "^0.27.4",
        "fflate": "^0.8.2",
        "nax-ccuilib": "github:krypciak/nax-ccuilib",
        "node": "^25.8.1",
        "prettier": "3.8.1",
        "setimmediate": "^1.0.5",
        "socket.io": "^4.8.3",
        "socket.io-adapter": "^2.5.6",
        "socket.io-client": "^4.8.3",
        "spdy": "^4.0.2",
        "ts-binarifier": "github:krypciak/ts-binarifier",
        "typescript": "^6.0.2",
        "ultimate-crosscode-typedefs": "github:krypciak/ultimate-crosscode-typedefs",
        "ws": "^8.21.0"
    }
}
